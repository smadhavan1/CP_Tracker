<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>CP Tracker</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
	<link rel="stylesheet" href="/css/home.css">
</head>
<body class="d-flex flex-column text-center text-white bg-dark">
		<div class="cover-container d-flex w-100 p-3 mx-auto flex-column">
			<header class="mb-auto">
				<h3 class="mb-0">CP Tracker</h3>
				<div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
					<nav class="nav nav-masthead justify-content-center">
						<a class="nav-link active" aria-current="page" href="#">Home</a>
					</nav>
					<nav class="nav nav-masthead justify-content-center ms-md-auto">
						<% if(!currentUser) { %>
						<a class="nav-link" href="/login">Login</a>
						<a class="nav-link" href="/register">Register</a>
						<% } else { %>
						<a class="nav-link" href="/logout">Logout</a>
						<% } %>
					</nav>
				</div>
			</header>
			<main class="px-3">
				<h1>CP Tracker</h1>
				<p class="lead">
					A simple tracker for your CP grind
				</p>
				<% if(!currentUser) { %>
					<a href="/register" class="btn btn-lg btn-secondary font-weight-bold border-white bg-white">Register</a>
				<% } else { %>
					<a href="/dashboard" class="btn btn-lg btn-secondary font-weight-bold border-white bg-white">Dashboard</a>
				<% } %>
			</main>
			<section class="mt-auto text-white-50">
				<div class="scroll-indicator">
				<p class="mb-0">See features</p>
				<p class="mb-0 arrow">↓</p>
				</div>
			</section>
		</div>
		<section id="features" class="py-5 text-white">
			<div class="container">
				<div class="row align-items-center mb-5">
					<div class="col-md-6 text-md-start mb-4 mb-md-0">
						<h2 class="fw-bold">Difficulty Distribution</h2>
						<p class="text-secondary">Track easy, medium, and hard questions.</p>
					</div>
					<div class="col-md-6">
						<img src="/png/DifficultyDistribution.png" alt="Difficulty Distribution" class="img-fluid rounded shadow">
					</div>
				</div>

				<div class="row align-items-center mb-5">
					<div class="col-md-6 text-md-end mb-4 mb-md-0">
						<h2 class="fw-bold">Status Distribution</h2>
						<p class="text-secondary">Track solved vs attempted questions.</p>
					</div>
					<div class="col-md-6 order-md-first">
						<img src="/png/StatusDistribution.png" alt="Status Distribution" class="img-fluid rounded shadow">
					</div>
				</div>

				<div class="row align-items-center mb-5">
					<div class="col-md-6 text-md-start mb-4 mb-md-0">
						<h2 class="fw-bold">Platform Distribution</h2>
						<p class="text-secondary">Your most used coding sites.</p>
					</div>
					<div class="col-md-6">
						<img src="/png/PlatformDistribution.png" alt="Platform Distribution" class="img-fluid rounded shadow">
					</div>
				</div>

				<div class="row align-items-center mb-5">
					<div class="col-md-6 text-md-end mb-4 mb-md-0">
						<h2 class="fw-bold">Tag Distribution</h2>
						<p class="text-secondary">Your most added tags.</p>
					</div>
					<div class="col-md-6 order-md-first">
						<img src="/png/TagDistribution.png" alt="Tag Distribution" class="img-fluid rounded shadow">
					</div>
				</div>

				<div class="row align-items-center mb-5">
					<div class="col-md-6 text-md-start mb-4 mb-md-0">
						<h2 class="fw-bold">Search, Sort and Filter</h2>
						<p class="text-secondary">Filter by title, difficulty, platform, status and tags</p>
					</div>
					<div class="col-md-6">
						<img src="/png/SearchFilter.png" alt="Search and Filter" class="img-fluid rounded shadow">
					</div>
				</div>

				<div class="row align-items-center">
					<div class="col-md-6 text-md-end mb-4 mb-md-0">
						<h2 class="fw-bold">Question List</h2>
						<p class="text-secondary">Manage your own list of questions.</p>
					</div>
					<div class="col-md-6 order-md-first">
						<img src="/png/QuestionList.png" alt="Question List" class="img-fluid rounded shadow">
					</div>
				</div>
			</div>
		</section>
		<footer class="d-flex justify-content-center align-items-center py-1 mt-auto">
			<div class="text-center">
				<span class="text-white">&copy; 2026 S Madhavan</span>
			</div>
		</footer>
		<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
	</body>
</html>
