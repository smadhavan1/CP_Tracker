<%- layout('layouts/boilerplate') %>
<div class="my-3 container">
	<h1 class="text-center">Add question</h1>
	<div class="col-md-7 mx-auto">
		<form action="/questions" method="post">
			<div class="container">
				<div class="mb-3">
					<label for="ID">Question ID</label>
					<input type="text" class="form-control" name="question[ID]" id="ID" placeholder="Enter the question ID" required autofocus />
				</div>
				<div class="mb-3">
					<label for="title">Question Title</label>
					<input type="text" class="form-control" name="question[title]" id="title" placeholder="Enter the question title" required />
				</div>
				<div class="mb-3">
					<label for="link">Question link</label>
					<input type="text" class="form-control" name="question[link]" id="link" placeholder="Enter the question link" required />
				</div>
				<div class="mb-3">
					<label for="difficulty">Difficulty</label>
					<select class="form-select" name="question[difficulty]" id="difficulty" required>
						<% for(let diff of difficultyLevels){{ { }}
						%>
						<option value="<%= diff %>"><%= diff %></option>
						<%{{ }

						}}%>
					</select>
				</div>
				<div class="mb-3">
					<label for="platform">Platform</label>
					<select class="form-select" name="question[platform]" id="platform" required>
						<% for(let platform of platforms){{ { }}
						%>
						<option value="<%= platform %>"><%= platform %></option>
						<%{{ } }}%>
					</select>
				</div>
				<div class="mb-3">
					<label for="status">Status</label>
					<select class="form-select" name="question[status]" id="status" required>
						<% for(let status of statusOptions){{ { }}
						%>
						<option value="<%= status %>"><%= status %></option>
						<%{{ } }}%>
					</select>
				</div>
				<div class="mb-3 container">
					<label for="tags">Tags</label>
					<div class="row">
						<% tagList.forEach((tag,idx) => {{ { }} %> <% if(idx%14===0) {{ { }}%>
						<div class="col">
							<% {{ } }} %> <label><input type="checkbox" name="question[tags]" value="<%= tag %>" /> <%= tag %></label><br />
							<% if((idx+1)%14===0) {{ { }}%>
						</div>
						<% {{ } }} %> <% {{ } }}) %>
					</div>
				</div>
				<div class="mb-3">
					<label for="solvedDate">Solved date</label>
					<input type="date" class="form-control" name="question[solvedDate]" id="solvedDate" placeholder="Enter the solving date" />
				</div>
				<div class="mb-3">
					<label for="timeTaken">Time taken</label>
					<input type="number" class="form-control" name="question[timeTaken]" id="timeTaken" placeholder="Enter the time taken in minutes" min="0" />
				</div>
				<div class="mb-3">
					<label for="notes">Notes</label>
					<textarea class="form-control" name="question[notes]" id="notes" placeholder="Enter notes (if any)" rows="5" cols="30"></textarea>
				</div>
				<div class="mb-3">
					<div class="form-check form-switch">
						<label class="form-check-label" for="favourite">Favourite</label>
						<input class="form-check-input" type="checkbox" role="switch" name="question[favourite]" id="favourite" />
					</div>
				</div>
				<div class="mb-3">
					<label for="solutionLink">Solution link</label>
					<input type="text" class="form-control" name="question[solutionLink]" id="solutionLink" placeholder="Enter the solution link" />
				</div>
				<div class="mb-3">
					<label for="lastRevisionDate">Last revision date</label>
					<input type="date" class="form-control" name="question[lastRevisionDate]" id="lastRevisionDate" placeholder="Enter the last revision date" />
				</div>
				<div class="mb-3">
					<label for="nextRevisionDate">Next revision date</label>
					<input type="date" class="form-control" name="question[nextRevisionDate]" id="nextRevisionDate" placeholder="Enter the next revision date" />
				</div>
				<div class="mb-3">
					<label for="revisionCount">Revision count</label>
					<input type="number" class="form-control" name="question[revisionCount]" id="revisionCount" placeholder="Enter the revision count" min="0" value="0" />
				</div>
				<button>Submit</button>
			</div>
		</form>
	</div>
</div>
